TOKEN=your-bot-token
CLIENT_ID=your-discord-application-id

# Opcional: sitio público para la verificación
PUBLIC_BASE_URL=https://example.com
TERMS_URL=https://example.com/terms
PRIVACY_URL=https://example.com/privacy
BOT_INVITE_URL=https://discord.com/oauth2/authorize?client_id=your-discord-application-id&permissions=0&scope=bot%20applications.commands

# Si quieres que el bot sirva las páginas legales desde este mismo proceso
ENABLE_LEGAL_SITE=true
LEGAL_PORT=3000

# Ajusta los permisos del enlace de instalación si usas CLIENT_ID
BOT_PERMISSIONS=0

# Integración con la web (UY Demonlist) — DMs automáticos al aceptar/rechazar submissions
